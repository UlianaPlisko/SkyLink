<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="12dp"
    android:paddingEnd="16dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <TextView
        android:id="@+id/tvAvatarInitials"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_logo_circle"
        android:gravity="center"
        android:textColor="@color/color_accent"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvMessageReceived"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_chat_bubble_received"
        android:maxWidth="260dp"
        android:padding="14dp"
        android:textColor="@color/black"
        android:textSize="16sp"
        app:layout_constraintStart_toEndOf="@id/tvAvatarInitials"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="8dp" />

    <TextView
        android:id="@+id/tvTimeReceived"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="time"
        android:textColor="@color/color_accent"
        android:textSize="11sp"
        app:layout_constraintTop_toBottomOf="@id/tvMessageReceived"
        app:layout_constraintStart_toStartOf="@id/tvMessageReceived"
        android:layout_marginTop="4dp" />
</androidx.constraintlayout.widget.ConstraintLayout>