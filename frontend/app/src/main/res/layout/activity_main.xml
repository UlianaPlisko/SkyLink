<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:background="@color/color_sky_background"
    android:clipToPadding="false">

    <!-- Sky View -->
    <com.codepalace.accelerometer.ui.view.SkyView
        android:id="@+id/skyView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/color_sky_background"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="54dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:background="@color/overlay_stroke"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/menu"
            android:padding="4dp"
            app:srcCompat="@drawable/ic_menu_24"
            app:tint="@color/color_accent" />

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="11:30"
            android:textColor="@color/color_accent"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnSearch"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/search"
            android:padding="4dp"
            app:srcCompat="@drawable/ic_search_24"
            app:tint="@color/color_accent" />
    </LinearLayout>

    <!-- Bottom left chat -->
    <ImageButton
        android:id="@+id/btnChat"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="20dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/chat"
        android:padding="6dp"
        app:srcCompat="@drawable/ic_chat_24"
        app:tint="@color/color_accent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Bottom right calendar -->
    <ImageButton
        android:id="@+id/btnCalendar"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="20dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/calendar"
        android:padding="6dp"
        app:srcCompat="@drawable/ic_calendar_24"
        app:tint="@color/color_accent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Compass -->
    <!-- Compass -->
    <LinearLayout
        android:id="@+id/compassContainer"
        android:layout_width="220dp"
        android:layout_height="140dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="8dp"
        android:paddingBottom="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.codepalace.accelerometer.ui.view.HalfCompassView
            android:id="@+id/halfCompassView"
            android:layout_width="200dp"
            android:layout_height="90dp" />

        <TextView
            android:id="@+id/tvDegrees"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="352°"
            android:textColor="@color/color_accent"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDirectionHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="North"
            android:textColor="@color/color_text_primary"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Loading overlay -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/color_primary"
        android:clickable="true"
        android:focusable="true"
        android:alpha="0"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.codepalace.accelerometer.ui.view.LoadingStarsView
            android:id="@+id/loadingStars"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/starPreviewPanel"
        android:layout_width="0dp"
        android:layout_height="88dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="90dp"
        android:orientation="vertical"
        android:background="@drawable/bg_card_menu"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:padding="12dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tvPreviewName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Capella"
            android:textColor="@color/color_primary"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvPreviewType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Spectroscopic Binary"
            android:textColor="@color/color_primary"
            android:textSize="14sp" />
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/searchOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="#CC000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ── Search bar row ── -->
        <LinearLayout
            android:id="@+id/searchBarRow"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/overlay_stroke"
            android:paddingHorizontal="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageButton
                android:id="@+id/btnSearchClose"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Close search"
                android:padding="4dp"
                app:srcCompat="@drawable/ic_back"
                app:tint="@color/color_accent" />

            <EditText
                android:id="@+id/searchInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="@android:color/transparent"
                android:hint="Search stars, planets…"
                android:textColor="@color/color_accent"
                android:textColorHint="@color/color_text_primary"
                android:textSize="16sp"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"
                android:maxLines="1" />

            <ImageButton
                android:id="@+id/btnSearchClear"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Clear search"
                android:padding="4dp"
                android:visibility="gone"
                app:srcCompat="@drawable/ic_close"
                app:tint="@color/color_accent" />

        </LinearLayout>

        <!-- ── Results panel — anchored below the search bar, fills bottom half ── -->
        <LinearLayout
            android:id="@+id/searchResultsPanel"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:background="@color/color_sky_background"
            android:paddingTop="4dp"

            app:layout_constraintTop_toBottomOf="@id/searchBarRow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"

            app:layout_constraintHeight_percent="0.4">

            <TextView
                android:id="@+id/tvSearchEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:text="No objects found"
                android:textColor="@color/color_text_primary"
                android:textSize="14sp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSearchResults"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="16dp"
                android:visibility="gone" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
