<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/dark_blue">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvBackSignup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:textColor="@color/accent_gold"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvSignupTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Account Now!"
            android:textColor="@color/accent_gold"
            android:textSize="34sp"
            android:textStyle="bold"
            android:layout_marginTop="48dp"
            android:layout_gravity="center_horizontal" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Username"
            android:textColor="@color/accent_gold"
            android:textSize="18sp"
            android:layout_marginTop="36dp"
            android:layout_gravity="center_horizontal" />

        <EditText
            android:id="@+id/etSignupUsername"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_auth_input"
            android:hint="Username"
            android:textColorHint="@color/text_primary_light"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary_light"
            android:inputType="textPersonName" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textColor="@color/accent_gold"
            android:textSize="18sp"
            android:layout_marginTop="20dp"
            android:layout_gravity="center_horizontal" />

        <EditText
            android:id="@+id/etSignupEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_auth_input"
            android:hint="Email"
            android:textColorHint="@color/text_primary_light"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary_light"
            android:inputType="textEmailAddress" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textColor="@color/accent_gold"
            android:textSize="18sp"
            android:layout_marginTop="20dp"
            android:layout_gravity="center_horizontal" />

        <EditText
            android:id="@+id/etSignupPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_auth_input"
            android:hint="Password"
            android:textColorHint="@color/text_primary_light"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary_light"
            android:inputType="textPassword" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Repeat Password"
            android:textColor="@color/accent_gold"
            android:textSize="18sp"
            android:layout_marginTop="20dp"
            android:layout_gravity="center_horizontal" />

        <EditText
            android:id="@+id/etSignupRepeatPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_auth_input"
            android:hint="Repeat Password"
            android:textColorHint="@color/text_primary_light"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary_light"
            android:inputType="textPassword" />

        <TextView
            android:id="@+id/tvSelectRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select your role"
            android:textColor="@color/accent_gold"
            android:textSize="20sp"
            android:layout_marginTop="28dp"
            android:layout_gravity="center_horizontal" />

        <RadioGroup
            android:id="@+id/rgRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp">

            <RadioButton
                android:id="@+id/rbObserver"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Observer"
                android:textColor="@color/accent_gold"
                android:buttonTint="@color/accent_gold"
                android:layout_marginEnd="28dp" />

            <RadioButton
                android:id="@+id/rbContributor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contributor"
                android:textColor="@color/accent_gold"
                android:buttonTint="@color/accent_gold" />
        </RadioGroup>

        <Button
            android:id="@+id/btnSignup"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/bg_auth_button"
            android:text="Sign Up"
            android:textAllCaps="false"
            android:textColor="@color/dark_blue"
            android:textSize="24sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account? "
                android:textColor="@color/accent_gold"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvGoLoginFromSignup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Login"
                android:textColor="@color/accent_gold"
                android:textStyle="bold"
                android:textSize="14sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>