<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="16dp"
    android:paddingEnd="12dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- Sent message bubble (right aligned) -->
    <TextView
        android:id="@+id/tvMessageSent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_chat_bubble_sent"
        android:maxWidth="260dp"
        android:padding="14dp"
        android:textColor="@color/black"
        android:textSize="16sp"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Time (aligned to the right of the bubble) -->
    <TextView
        android:id="@+id/tvTimeSent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="time"
        android:textColor="@color/color_accent"
        android:textSize="11sp"
        android:layout_marginTop="4dp"

        app:layout_constraintTop_toBottomOf="@id/tvMessageSent"
        app:layout_constraintEnd_toEndOf="@id/tvMessageSent" />

</androidx.constraintlayout.widget.ConstraintLayout>