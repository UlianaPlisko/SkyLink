<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/settingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_blue">

    <RelativeLayout
        android:id="@+id/headerBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:paddingStart="10dp"
        android:paddingTop="8dp"
        android:paddingEnd="10dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@android:color/transparent"
            android:contentDescription="Back"
            android:padding="4dp"
            android:src="@drawable/ic_back"
            app:tint="@color/accent_gold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Settings"
            android:textColor="@color/accent_gold"
            android:textSize="28sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <View
        android:id="@+id/headerDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/accent_gold"
        app:layout_constraintTop_toBottomOf="@id/headerBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/settingsList"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toBottomOf="@id/headerDivider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/itemAccount"
            android:layout_marginTop="8dp"
            style="@style/SettingsRow">

            <ImageView
                style="@style/SettingsRowIcon"
                android:contentDescription="Account"
                android:src="@drawable/ic_profile" />

            <TextView
                style="@style/SettingsRowTitle"
                android:text="Account" />

            <ImageView
                style="@style/SettingsChevron"
                android:contentDescription="Open account settings"
                android:src="@drawable/ic_arrow_right" />
        </LinearLayout>

        <LinearLayout
            style="@style/SettingsRow">

            <ImageView
                style="@style/SettingsRowIcon"
                android:contentDescription="Notification"
                android:src="@drawable/ic_notification" />

            <TextView
                style="@style/SettingsRowTitle"
                android:text="Notification" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchNotifications"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            style="@style/SettingsRow">

            <ImageView
                style="@style/SettingsRowIcon"
                android:contentDescription="Red mode"
                android:src="@drawable/ic_moon" />

            <TextView
                style="@style/SettingsRowTitle"
                android:text="Red Mode" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchRedMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            style="@style/SettingsRow">

            <ImageView
                style="@style/SettingsRowIcon"
                android:contentDescription="Sensors"
                android:src="@drawable/ic_sensor" />

            <TextView
                style="@style/SettingsRowTitle"
                android:text="Sensors" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:text="Manual/Auto"
                android:textColor="@color/dark_blue"
                android:textSize="10sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchSensors"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/itemLocation"
            style="@style/SettingsRow">

            <ImageView
                style="@style/SettingsRowIcon"
                android:contentDescription="Location"
                android:src="@drawable/ic_location" />

            <TextView
                style="@style/SettingsRowTitle"
                android:text="Location" />

            <ImageView
                style="@style/SettingsChevron"
                android:contentDescription="Open location settings"
                android:src="@drawable/ic_arrow_right" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
