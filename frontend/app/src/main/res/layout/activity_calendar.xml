<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_blue">

    <RelativeLayout
        android:id="@+id/headerLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_back"
            app:tint="@color/accent_gold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvCurrentDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="August 28, 2020"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_gold"/>

                <TextView
                    android:id="@+id/tvDateLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today"
                    android:textSize="14sp"
                    android:textColor="@color/accent_gold"
                    android:alpha="0.7"/>

            </LinearLayout>

    </RelativeLayout>

    <!-- DIVIDER -->
    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/accent_gold"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- WEEK SELECTOR CARD -->
    <LinearLayout
        android:id="@+id/weekDaysContainer"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/bg_menu_item"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnPrevWeek"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_back"
            app:tint="@color/dark_blue" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvWeekDays"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingHorizontal="8dp"/>

        <ImageButton
            android:id="@+id/btnNextWeek"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_arrow_right"
            app:tint="@color/dark_blue" />
    </LinearLayout>

    <!-- TITLE -->
    <TextView
        android:id="@+id/tvScheduledTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Scheduled"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/accent_gold"
        android:layout_marginTop="24dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/weekDaysContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- EVENTS LIST (CARD STYLE) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvScheduledEvents"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_menu_item"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvScheduledTitle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    ```

</androidx.constraintlayout.widget.ConstraintLayout>
