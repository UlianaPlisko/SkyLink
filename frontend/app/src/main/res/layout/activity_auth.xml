<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/authRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_blue"
    android:padding="24dp">

    <LinearLayout
        android:id="@+id/logoContainer"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_logo_circle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="72dp">

        <ImageView
            android:id="@+id/logoImage"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="@string/app_name" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvLogoName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/accent_gold"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/logoContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp" />

    <TextView
        android:id="@+id/tvAuthHint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="In order to use these features please login to your account"
        android:textAlignment="center"
        android:textColor="@color/accent_gold"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/tvLogoName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"
        android:layout_marginHorizontal="24dp" />

    <Button
        android:id="@+id/btnGoLogin"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_auth_button"
        android:text="Login"
        android:textAllCaps="false"
        android:textColor="@color/dark_blue"
        android:textSize="24sp"
        app:layout_constraintTop_toBottomOf="@id/tvAuthHint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="48dp"
        android:layout_marginHorizontal="36dp" />

    <Button
        android:id="@+id/btnGoSignup"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_auth_button"
        android:text="Sign Up"
        android:textAllCaps="false"
        android:textColor="@color/dark_blue"
        android:textSize="24sp"
        app:layout_constraintTop_toBottomOf="@id/btnGoLogin"
        app:layout_constraintStart_toStartOf="@id/btnGoLogin"
        app:layout_constraintEnd_toEndOf="@id/btnGoLogin"
        android:layout_marginTop="20dp" />

    <Button
        android:id="@+id/btnGoogle"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_auth_button"
        android:text="@string/continue_with_google"
        android:textAllCaps="false"
        android:textColor="@color/dark_blue"
        android:textSize="20sp"
        app:layout_constraintTop_toBottomOf="@id/btnGoSignup"
        app:layout_constraintStart_toStartOf="@id/btnGoSignup"
        app:layout_constraintEnd_toEndOf="@id/btnGoSignup"
        android:layout_marginTop="20dp" />

</androidx.constraintlayout.widget.ConstraintLayout>